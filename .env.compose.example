# Host path to a generated krx-rule-markdown corpus.
KRX_RULE_DATA_DIR=/opt/krx-rule-data

# Host path containing `current` and immutable BM25/vector generations.
# Use this repository's ./index when it matches the corpus, or a generated index directory.
KRX_RULE_INDEX_DIR=/opt/krx-rule-index

# Required for HTTP mode.
RULE_MCP_BEARER_TOKEN=change-me

# Production releases should set both values from the GHCR publish workflow.
# RULE_MCP_IMAGE=ghcr.io/chromato99/krx-rule-mcp@sha256:<manifest-digest>
# RULE_MCP_SERVER_IMAGE_DIGEST=sha256:<manifest-digest>

# Optional host ports.
RULE_MCP_PORT=8080
RULE_MCP_TEI_PORT=18081

# Required user selection. Choose a TEI image compatible with your target
# architecture and pin its immutable digest. krx-rule-mcp does not select one.
RULE_MCP_TEI_IMAGE=
RULE_MCP_TEI_IMAGE_DIGEST=
# Example shape only:
# RULE_MCP_TEI_IMAGE=registry.example/tei@sha256:<manifest-digest>
# RULE_MCP_TEI_IMAGE_DIGEST=sha256:<manifest-digest>

# Default repository vector index / TEI model. The same revision and embedding
# settings must be used when generating the vector index.
# RULE_MCP_TEI_MODEL_ID=intfloat/multilingual-e5-small
# KRX_EMBEDDING_MODEL=intfloat/multilingual-e5-small
KRX_EMBEDDING_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
# KRX_EMBEDDING_DIMENSIONS=384
# compose.yaml defaults prefixes to "query: " and "passage: ".
# Set KRX_EMBEDDING_QUERY_PREFIX and KRX_EMBEDDING_DOCUMENT_PREFIX explicitly
# when using another embedding model; empty values disable prefixes.
