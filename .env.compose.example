# Host path to a generated krx-rule-markdown corpus.
KRX_RULE_DATA_DIR=/opt/krx-rule-data

# Host path for BM25/vector snapshots.
# Use this repository's ./index when it matches the corpus, or a generated index directory.
KRX_RULE_INDEX_DIR=/opt/krx-rule-index

# Required for HTTP mode.
KRX_MCP_BEARER_TOKEN=change-me

# Optional host ports.
KRX_MCP_PORT=8080
KRX_TEI_PORT=18081

# Default repository vector index / TEI model:
# KRX_TEI_MODEL_ID=intfloat/multilingual-e5-small
# KRX_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# KRX_EMBEDDING_DIMENSIONS=384
# compose.yaml defaults prefixes to "query: " and "passage: ".
# Set KRX_EMBEDDING_QUERY_PREFIX and KRX_EMBEDDING_DOCUMENT_PREFIX explicitly
# when using another embedding model; empty values disable prefixes.
