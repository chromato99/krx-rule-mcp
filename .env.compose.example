# Copy this file to .env before running docker compose.

# Required: host path containing a generated krx-rule-markdown data/ corpus.
KRX_RULE_DATA_DIR=/opt/krx-rule-data

# Required for HTTP MCP. Change this before exposing the service.
KRX_MCP_BEARER_TOKEN=change-me

# Host port for the MCP HTTP server.
KRX_MCP_PORT=8080

# Optional comma-separated browser origins.
# KRX_MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://chatgpt.com

# Index paths inside the container-mounted corpus.
KRX_INDEX_PATH=/app/data/index/bm25.krxidx
KRX_VECTOR_INDEX_PATH=/app/data/index/vectors.krxvec

# Compose starts a Hugging Face TEI embeddings sidecar by default.
# Set this false for BM25-only serving.
KRX_VECTOR_SEARCH_ENABLED=true

# OpenAI-compatible embeddings settings. Defaults target the local TEI sidecar.
OPENAI_API_KEY=local
KRX_EMBEDDING_BASE_URL=http://krx-rule-embeddings:80/v1
KRX_EMBEDDING_MODEL=intfloat/multilingual-e5-small
KRX_EMBEDDING_DIMENSIONS=384
KRX_EMBEDDING_QUERY_PREFIX="query: "
KRX_EMBEDDING_DOCUMENT_PREFIX="passage: "

# Host port for directly probing TEI from the host.
KRX_TEI_PORT=18081
KRX_TEI_MODEL_ID=intfloat/multilingual-e5-small
